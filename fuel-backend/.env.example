PORT=5002
NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=8h

# M-Pesa Daraja API (Safaricom) — get from developer.safaricom.co.ke
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your-daraja-passkey
DARAJA_CALLBACK_URL=https://your-domain.vercel.app
DARAJA_ENV=sandbox

# IntaSend (PesaLink + Bank Transfers) — get from intasend.com
INTASEND_PUBLISHABLE_KEY=your-intasend-publishable-key
INTASEND_SECRET_KEY=your-intasend-secret-key
INTASEND_IS_SANDBOX=true

# Africa's Talking (SMS) — get from africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=FUELFLOW

# Equity Bank Jenga API — get from jengahq.io
JENGA_ENV=sandbox
JENGA_API_KEY=your-jenga-api-key
JENGA_MERCHANT_CODE=your-jenga-merchant-code
JENGA_CONSUMER_SECRET=your-jenga-consumer-secret
# RSA Private Key (generate a 2048-bit RSA key pair, upload public to JengaHQ portal)
# Paste the full private key with \n for newlines
JENGA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----
EQUITY_ACCOUNT_NUMBER=your-equity-account-number
EQUITY_COUNTRY_CODE=KE

# Business Info
BUSINESS_NAME=FuelFlow Pro

# CORS
FRONTEND_URL=http://localhost:5174
